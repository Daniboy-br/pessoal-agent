NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_URL=

# Browser/client key. Prefer legacy anon or publishable key depending on Supabase project config.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only keys. Never expose these in client code.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# CLI/Management API token for linking/pushing migrations. Local only.
SUPABASE_ACCESS_TOKEN=
